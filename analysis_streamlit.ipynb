
import streamlit as st
import pandas as pd
import matplotlib.pyplot as plt
from wordcloud import WordCloud, STOPWORDS
from textblob import TextBlob

st.title("E-commerce Review Analysis Dashboard")

df = pd.read_csv("Reviews.csv", nrows=20000)

# WORD CLOUD
text = " ".join(df['Text'].astype(str))
wc = WordCloud(stopwords=set(STOPWORDS),
               max_words=100,
               background_color="white").generate(text)

st.subheader("Word Cloud")
fig, ax = plt.subplots()
ax.imshow(wc)
ax.axis("off")
st.pyplot(fig)

# SENTIMENT
df['sentiment'] = df['Text'].apply(lambda x: TextBlob(str(x)).sentiment.polarity)
df['label'] = df['sentiment'].apply(lambda x: 'positive' if x>0 else 'negative')

st.subheader("Sentiment Distribution")
st.bar_chart(df['label'].value_counts())

# BEHAVIOUR (Ratings)
st.subheader("Customer Rating Pattern")
st.bar_chart(df['Score'].value_counts().sort_index())

# USER INPUT
st.subheader("Try Your Own Review")
user_input = st.text_area("Enter review:")

if st.button("Analyze"):
    polarity = TextBlob(user_input).sentiment.polarity
    if polarity > 0:
        st.success("Positive Review")
    else:
        st.error("Negative Review")
